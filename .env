SERVER_PORT=8443
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5671
RABBITMQ_USER=adopti
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD}
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=https
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=${ELASTICSEARCH_PASSWORD}
ELASTICSEARCH_CA_PATH=/app/certs/ca.crt
ELASTICSEARCH_INDEX=pets
MATCH_SCORE_THRESHOLD=0.3
MATCH_MAX_DAYS=90
MATCH_MAX_RESULTS=20
SSL_KEYSTORE=/app/certs/keystore.p12
SSL_KEYSTORE_PASSWORD=${SSL_KEYSTORE_PASSWORD}
SSL_TRUSTSTORE=/app/certs/truststore.jks
SSL_TRUSTSTORE_PASSWORD=${SSL_TRUSTSTORE_PASSWORD}
