# Variables consumidas por matching-service (Kotlin/Spring Boot).
# Fuente unica de verdad para Docker Compose.

# -- Elasticsearch --
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_INDEX=pets

# -- RabbitMQ --
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5671
RABBITMQ_USER=adopti
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD}

# -- Matching Configuration --
MATCH_SCORE_THRESHOLD=0.3
MATCH_MAX_DAYS=90
MATCH_MAX_RESULTS=20
