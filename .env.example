# ── Elasticsearch ──────────────────────────────────
# En Docker Compose usar: elasticsearch
# En local usar: localhost
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_INDEX=pets

# ── RabbitMQ ───────────────────────────────────────
# En Docker Compose usar: rabbitmq
# En local usar: localhost
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=adopti
RABBITMQ_PASSWORD=rabbitmq_secret

# ── Matching Configuration ─────────────────────────
MATCH_SCORE_THRESHOLD=0.3
MATCH_MAX_DAYS=90
MATCH_MAX_RESULTS=20
