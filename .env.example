# Variables consumidas por matching-service (Kotlin/Spring Boot). Fuente
# única de verdad para Docker Compose (cargado vía env_file en
# Compose/docker-compose.yml).
#
# Para correr el servicio FUERA de Docker, sustituir hostnames Docker
# (elasticsearch, rabbitmq) por localhost.

# ── Elasticsearch ──────────────────────────────────
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_INDEX=pets

# ── RabbitMQ ───────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=adopti
RABBITMQ_PASSWORD=rabbitmq_secret

# ── Matching Configuration ─────────────────────────
MATCH_SCORE_THRESHOLD=0.3
MATCH_MAX_DAYS=90
MATCH_MAX_RESULTS=20
